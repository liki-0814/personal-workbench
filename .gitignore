# Contains mutation testing data
**/mutants.out*/

# Node/Vite build artifacts and dependencies
/web/node_modules/
/web/dist/
/web/.npm-cache/

# Test results/runs
/test-results/

# IDE directories and files
/.idea/
.DS_Store

# Local env files
.env
.env.local
.env.*.local
